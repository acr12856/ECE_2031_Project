WIDTH=16;
DEPTH=2048;

ADDRESS_RADIX=HEX;
DATA_RADIX=HEX;

CONTENT BEGIN
0000: 90C0; -- 	IN     ADC
0001: 9801; -- 	OUT    LEDs
0002: 9804; -- 	OUT    Hex0
0003: 1005; -- 	STORE  Pattern
0004: 5800; -- 	JUMP   showValue
0005: 0000; -- Pattern:   DW 0
0006: 0001; -- Bit0:      DW &B0000000001
0007: 0200; -- Bit9:      DW &B1000000000
0008: 0004; -- Bit2:	   DW &B0000000100
[0009..07FF] : 0000; -- [empty memory]
END;
